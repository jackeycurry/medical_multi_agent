# 复制本文件为 .env 并填入真实值；.env 不要提交到版本库
# 阿里云 DashScope（通义千问）—— 在 https://dashscope.console.aliyun.com 申请
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 数据库；默认相对路径要求启动时 cwd=backend/
DATABASE_URL=sqlite:///./data/ai_doctor.db

# JWT —— 生产环境必须用强随机值，可用：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=please-change-this-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# /api/v1/* API Key 与医院绑定，强制多租户隔离
# 格式：key1:hospital_id1,key2:hospital_id2（hospital_id 来自 hospitals 表的 id）
# 生成方式：python -c "import secrets; print('demo_' + secrets.token_urlsafe(24))"
# 例：EXTERNAL_API_KEYS=demo_xxxxxxxx:1,demo_yyyyyyyy:2
EXTERNAL_API_KEYS=
EXTERNAL_API_RATE_LIMIT_PER_MIN=60
